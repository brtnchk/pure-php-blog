{
    "name": "oleg/blog",
    "description": "Simple blog on pure PHP with MySQL and Smarty",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "smarty/smarty": "^4.3",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}