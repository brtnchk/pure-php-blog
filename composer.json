    "type": "project",
    "require": {
        "php": ">=8.2",
        "smarty/smarty": "^5.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true
    }
}