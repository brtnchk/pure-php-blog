{
    "name": "oleg/blog",
    "description": "Simple blog on pure PHP with MySQL and Smarty",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "smarty/smarty": "^5.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "fix": "php-cs-fixer fix",
        "fix:check": "php-cs-fixer fix --dry-run --diff",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}